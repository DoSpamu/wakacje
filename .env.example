# ============================================================
# Supabase
# ============================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# Next.js (public vars — safe to expose to browser)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# Scraper settings
# ============================================================
# Playwright browser — chromium | firefox | webkit
SCRAPER_BROWSER=chromium
# Whether to run browser in headless mode (true/false)
SCRAPER_HEADLESS=true
# Max concurrent scraper pages per provider
SCRAPER_CONCURRENCY=2
# Delay between requests in ms
SCRAPER_DELAY_MS=2000
# Max retries per page load
SCRAPER_MAX_RETRIES=3
# Timeout for page navigation in ms
SCRAPER_TIMEOUT_MS=60000
# Enable snapshot saving (HTML) for debugging
SCRAPER_SAVE_SNAPSHOTS=false
# Directory to save snapshots
SCRAPER_SNAPSHOT_DIR=./snapshots

# ============================================================
# Enrichment (TripAdvisor / Google)
# ============================================================
# Delay between enrichment requests in ms
ENRICHMENT_DELAY_MS=3000
# Enable Google Reviews enrichment (requires more complex setup)
ENABLE_GOOGLE_ENRICHMENT=false
# Optional: Google Maps API key (for official data, not scraping)
GOOGLE_MAPS_API_KEY=

# ============================================================
# API trigger (optional — for secure scrape triggering from UI)
# ============================================================
SCRAPE_API_SECRET=change-this-to-a-secure-random-string

# ============================================================
# Scoring config override (path to custom scoring config JSON)
# ============================================================
SCORING_CONFIG_PATH=

# ============================================================
# Scrape filter defaults (used by run.ts when not set in UI)
# ============================================================
# Comma-separated canonical destinations
SCRAPE_DESTINATIONS=turkey,egypt,greece,spain,cyprus
# Comma-separated airport codes
SCRAPE_AIRPORTS=KTW,KRK
# Date range (YYYY-MM-DD) — leave empty to use today + 2 months
SCRAPE_DATE_FROM=
SCRAPE_DATE_TO=
# Night range
SCRAPE_NIGHTS_MIN=7
SCRAPE_NIGHTS_MAX=14
# Number of adults
SCRAPE_ADULTS=2
SCRAPE_CHILDREN=0
# Comma-separated star ratings (3,4,5)
SCRAPE_STARS=4,5
# Comma-separated board types
SCRAPE_BOARD_TYPES=all-inclusive,ultra-all-inclusive
# Whether to run TripAdvisor enrichment during scrape (true/false)
ENABLE_ENRICHMENT=true

# ============================================================
# Migration (optional — for pnpm migrate)
# ============================================================
# Get your access token from: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
