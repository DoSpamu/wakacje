{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && pnpm turbo run build --filter=@wakacje/web",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/enrich",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/price-alerts",
      "schedule": "0 9 * * *"
    }
  ]
}
